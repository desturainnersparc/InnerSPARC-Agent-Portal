# Django email provider configuration
# Copy this file to .env (local) or set these as environment variables in production.

# Local development defaults
DEBUG=True

# Choose provider: auto, smtp, resend, postmark, or brevo
# auto picks first configured provider in this order: postmark -> resend -> brevo -> smtp
EMAIL_PROVIDER=smtp

# Gmail SMTP setup (works without custom domain DNS)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=destura.innersparc@gmail.com
# Keep secrets out of the repo. Put the real password in a local `.env` or in Render env vars.
EMAIL_HOST_PASSWORD=innersparc1
DEFAULT_FROM_EMAIL=destura.innersparc@gmail.com
EMAIL_AUDIT_BCC=

# Public base URL for assets referenced in outbound emails
# Example: https://inner-sparc-portal-main.onrender.com
EMAIL_ASSET_BASE_URL=https://inner-sparc-portal-main.onrender.com

# Required when EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# Required when EMAIL_PROVIDER=postmark
# POSTMARK_SERVER_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# Required when EMAIL_PROVIDER=brevo
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxx

# Must be a verified sender/domain when using resend or postmark
# DEFAULT_FROM_EMAIL=hello@your-verified-domain.com

# Optional
EMAIL_TIMEOUT=20

# Optional override; leave commented to allow provider auto-selection in settings.py
# EMAIL_BACKEND=

# Optional database override. Example values:
# DATABASE_URL=mysql://username:password@127.0.0.1:3306/innersparc
# DATABASE_URL=mysql://username:password@localhost:3306/innersparc
