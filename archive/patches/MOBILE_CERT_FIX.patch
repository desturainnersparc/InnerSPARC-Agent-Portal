+/* ============================================================================ */
+/* FINAL AUTHORITATIVE MOBILE LAYOUT BLOCK                                     */
+/* Applied last to win cascade and fix mobile certificate distortion           */
+/* ============================================================================ */
+
+@media (max-width: 767px) {
+  .tpl1 .cert-section .cert-preview-wrapper {
+    display: flex !important;
+    justify-content: center !important;
+    align-items: flex-start !important;
+    overflow: visible !important;
