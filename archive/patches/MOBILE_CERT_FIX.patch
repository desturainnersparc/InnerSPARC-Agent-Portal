+  }
+
+  .tpl1 .cert-section .cert-preview-card {
+    width: 100% !important;
+    max-width: 100% !important;
+    min-width: 0 !important;
+    margin: 0 auto !important;
+    padding: 0 !important;
+  }
+
+  .tpl1 .cert-section .cert-canvas-scale {
+    width: var(--cert-fixed-width) !important;
+    margin: 0 auto !important;
+    transform-origin: top center !important;
+    --cert-scale: calc(min(1, (100vw - 24px) / var(--cert-fixed-width)));
+    transform: scale(var(--cert-scale)) !important;
+  }
+
+  .tpl1 .cert-section .cert-canvas-scale .cert-canvas-frame,
+  .tpl1 .cert-section .cert-canvas-scale .cert-document {
+    width: var(--cert-fixed-width) !important;
+    max-width: none !important;
+    aspect-ratio: var(--cert-ratio) !important;
+  }
+}
+
+@media (max-width: 420px) {
